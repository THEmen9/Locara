<%- /* ============================================================
        LOCARA — reserve.ejs
        Variables: booking (populated: listing, user), currentUser
   ============================================================ */ %>

<link rel="stylesheet" href="/css/payment.css">

<div class="lp-reserve">

  <!-- ── PAGE HEADER ─────────────────────────────────────────── -->
  <div class="lp-reserve__header">
    <a href="/listings/<%= booking.listing._id %>" class="lp-reserve__back">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Back to listing
    </a>
    <div class="lp-reserve__brand">
      <span class="lp-reserve__brand-dot"></span>Locara
    </div>
  </div>

  <!-- ── MAIN GRID ─────────────────────────────────────────────── -->
  <div class="lp-reserve__layout">

    <!-- LEFT: booking summary ───────────────────────────────── -->
    <main class="lp-reserve__details">
      <h1 class="lp-reserve__title">Confirm your booking</h1>
      <p class="lp-reserve__subtitle">Review details and choose how to pay</p>

      <!-- Listing card -->
      <div class="lp-summary-card">
        <% if(booking.listing.images && booking.listing.images.length) { %>
        <img
          class="lp-summary-card__img"
          src="<%= booking.listing.images[0].url.startsWith('http') ? booking.listing.images[0].url : '/' + booking.listing.images[0].url %>"
          alt="<%= booking.listing.title %>"
        >
        <% } %>
        <div class="lp-summary-card__body">
          <span class="lp-summary-card__type">Entire property</span>
          <h3 class="lp-summary-card__title"><%= booking.listing.title %></h3>
          <p class="lp-summary-card__loc">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= booking.listing.location %>, <%= booking.listing.country %>
          </p>
          <div class="lp-summary-card__rating">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <strong>4.8</strong> · 128 reviews
          </div>
        </div>
      </div>

      <!-- Trip details -->
      <section class="lp-trip">
        <h2 class="lp-section-title">Your trip</h2>
        <div class="lp-trip__grid">
          <div class="lp-trip__item">
            <span class="lp-trip__label">Check-in</span>
            <strong class="lp-trip__value"><%= new Date(booking.checkIn).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></strong>
          </div>
          <div class="lp-trip__item">
            <span class="lp-trip__label">Check-out</span>
            <strong class="lp-trip__value"><%= new Date(booking.checkOut).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></strong>
          </div>
          <div class="lp-trip__item">
            <span class="lp-trip__label">Guests</span>
            <strong class="lp-trip__value"><%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></strong>
          </div>
          <div class="lp-trip__item">
            <span class="lp-trip__label">Booking type</span>
            <strong class="lp-trip__value"><%= booking.bookingType === 'room' ? `${booking.roomsBooked} Room(s)` : 'Whole property' %></strong>
          </div>
        </div>
      </section>

      <!-- Cancellation policy -->
      <section class="lp-policy">
        <h2 class="lp-section-title">Cancellation policy</h2>
        <p class="lp-policy__text">
          Free cancellation before check-in date. After that, this reservation is non-refundable.
        </p>
      </section>

      <!-- Payment method chooser -->
      <section class="lp-payment-choice">
        <h2 class="lp-section-title">Choose payment method</h2>

        <form action="/bookings/<%= booking._id %>/choose-payment" method="POST" id="paymentChoiceForm">

          <div class="lp-payment-choice__options">

            <!-- Option A: Pay Now -->
            <label class="lp-payment-option lp-payment-option--selected" for="payNow">
              <input type="radio" name="paymentMethod" id="payNow" value="online" checked>
              <div class="lp-payment-option__icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              </div>
              <div class="lp-payment-option__body">
                <strong>Pay now</strong>
                <span>Secure online payment via Razorpay</span>
              </div>
              <div class="lp-payment-option__badge">Recommended</div>
              <div class="lp-payment-option__check">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
            </label>

            <!-- Option B: Pay at property -->
            <label class="lp-payment-option" for="payProperty">
              <input type="radio" name="paymentMethod" id="payProperty" value="property">
              <div class="lp-payment-option__icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <div class="lp-payment-option__body">
                <strong>Pay at property</strong>
                <span>Pay during check-in — no card needed now</span>
              </div>
              <div class="lp-payment-option__check">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
            </label>

          </div>

          <button type="submit" class="lp-cta-btn" id="continueBtn">
            Continue
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>

        </form>

      </section>
    </main>

    <!-- RIGHT: price summary ─────────────────────────────────── -->
    <aside class="lp-reserve__sidebar">
      <div class="lp-price-card">

        <% const nights = Math.ceil((new Date(booking.checkOut) - new Date(booking.checkIn)) / 86400000); %>
        <% const perNight = Math.round(booking.totalPrice / nights); %>

        <div class="lp-price-card__header">
          <div>
            <span class="lp-price-card__price">₹<%= perNight.toLocaleString('en-IN') %></span>
            <span class="lp-price-card__unit">/ night</span>
          </div>
          <div class="lp-price-card__stars">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            4.8 · 128
          </div>
        </div>

        <hr class="lp-price-card__divider">

        <div class="lp-price-card__rows">
          <div class="lp-price-card__row">
            <span>₹<%= perNight.toLocaleString('en-IN') %> × <%= nights %> night<%= nights>1?'s':'' %></span>
            <span>₹<%= booking.totalPrice.toLocaleString('en-IN') %></span>
          </div>
          <div class="lp-price-card__row">
            <span>Service fee</span>
            <span>₹0</span>
          </div>
          <div class="lp-price-card__row">
            <span>Taxes</span>
            <span>Included</span>
          </div>
        </div>

        <hr class="lp-price-card__divider">

        <div class="lp-price-card__total">
          <strong>Total</strong>
          <strong>₹<%= booking.totalPrice.toLocaleString('en-IN') %></strong>
        </div>

        <!-- Trust badge -->
        <div class="lp-trust">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Secure payment powered by <strong>Razorpay</strong></span>
        </div>

      </div>

      <!-- What's included -->
      <div class="lp-includes">
        <h3 class="lp-includes__title">What's included</h3>
        <ul class="lp-includes__list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0f766e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Instant confirmation</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0f766e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Free cancellation (check policy)</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0f766e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> 24/7 guest support</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0f766e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Locara booking protection</li>
        </ul>
      </div>
    </aside>

  </div><!-- /.lp-reserve__layout -->
</div><!-- /.lp-reserve -->

<script>
  /* Highlight selected payment option */
  document.querySelectorAll('.lp-payment-option input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.lp-payment-option').forEach(el => el.classList.remove('lp-payment-option--selected'));
      radio.closest('.lp-payment-option').classList.add('lp-payment-option--selected');
    });
  });

  /* Button label update */
  const form   = document.getElementById('paymentChoiceForm');
  const btn    = document.getElementById('continueBtn');
  form.addEventListener('change', () => {
    const val = form.paymentMethod.value;
    btn.innerHTML = val === 'online'
      ? 'Continue to payment <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>'
      : 'Confirm booking <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
  });
</script>
