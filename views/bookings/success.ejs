<%- /* ============================================================
        LOCARA — success.ejs
        Variables: booking (populated: listing, user), payAtProperty
   ============================================================ */ %>

<link rel="stylesheet" href="/css/payment.css">

<div class="lp-success">

  <!-- ── CONFETTI CANVAS (pure CSS) ─────────────────────────── -->
  <div class="lp-confetti" aria-hidden="true">
    <% for(let i=0; i<18; i++) { %>
    <div class="lp-confetti__piece lp-confetti__piece--<%= i % 6 %>"></div>
    <% } %>
  </div>

  <!-- ── SUCCESS CARD ───────────────────────────────────────── -->
  <div class="lp-success__card">

    <!-- Icon -->
    <div class="lp-success__icon-wrap">
      <% if(payAtProperty){ %>
      <div class="lp-success__icon lp-success__icon--property">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <% } else { %>
      <div class="lp-success__icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <% } %>
    </div>

    <!-- Headline -->
    <% if(payAtProperty){ %>
    <h1 class="lp-success__title">Booking confirmed!</h1>
    <p class="lp-success__sub">
      Your stay is reserved. You'll pay at the property during check-in.
    </p>
    <div class="lp-success__pay-note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      <strong>Payment due at check-in</strong> — bring cash or card
    </div>
    <% } else { %>
    <h1 class="lp-success__title">Payment successful!</h1>
    <p class="lp-success__sub">
      Your booking is confirmed. A confirmation has been sent to your email.
    </p>
    <% } %>

    <!-- Booking ID badge -->
    <div class="lp-success__id">
      Booking ID: <code><%= booking._id.toString().slice(-8).toUpperCase() %></code>
    </div>

    <!-- Summary grid -->
    <div class="lp-success__summary">

      <% if(booking.listing.images && booking.listing.images.length){ %>
      <img
        class="lp-success__img"
        src="<%= booking.listing.images[0].url.startsWith('http') ? booking.listing.images[0].url : '/' + booking.listing.images[0].url %>"
        alt="<%= booking.listing.title %>"
      >
      <% } %>

      <div class="lp-success__details">
        <h3 class="lp-success__listing-title"><%= booking.listing.title %></h3>
        <p class="lp-success__listing-loc">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <%= booking.listing.location %>, <%= booking.listing.country %>
        </p>

        <div class="lp-success__meta-grid">
          <div class="lp-success__meta">
            <span>Check-in</span>
            <strong><%= new Date(booking.checkIn).toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'long'}) %></strong>
          </div>
          <div class="lp-success__meta">
            <span>Check-out</span>
            <strong><%= new Date(booking.checkOut).toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'long'}) %></strong>
          </div>
          <div class="lp-success__meta">
            <span>Guests</span>
            <strong><%= booking.guests %> guest<%= booking.guests>1?'s':'' %></strong>
          </div>
          <div class="lp-success__meta">
            <span>Payment</span>
            <strong class="lp-success__status lp-success__status--<%= booking.paymentStatus %>">
              <%= booking.paymentStatus === 'paid' ? '✓ Paid' : '⏳ At property' %>
            </strong>
          </div>
        </div>

        <div class="lp-success__total">
          Total paid: <strong>₹<%= booking.totalPrice.toLocaleString('en-IN') %></strong>
          <% if(payAtProperty){ %>
          <span class="lp-success__total-note">(due at property)</span>
          <% } %>
        </div>
      </div>

    </div>
    <!-- Actions -->
    <div class="lp-success__actions">
      <a href="/my-bookings" role="tab" class="lp-success__btn lp-success__btn--primary">
        View my bookings
      </a>
      <a href="/listings" class="lp-success__btn lp-success__btn--ghost">
        Explore more stays
      </a>
    </div>

    <!-- Trust footer -->
    <div class="lp-success__footer">
      <div class="lp-success__footer-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Locara booking protection</span>
      </div>
      <div class="lp-success__footer-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.24H6.6a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.59 9.91a16 16 0 0 0 6.29 6.29l1.25-1.25a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>24/7 support available</span>
      </div>
    </div>

  </div><!-- /.lp-success__card -->

</div><!-- /.lp-success -->

<script>
  /* Simple confetti randomiser */
  document.querySelectorAll('.lp-confetti__piece').forEach((el, i) => {
    el.style.setProperty('--x', (Math.random() * 100) + 'vw');
    el.style.setProperty('--delay', (Math.random() * 1.5) + 's');
    el.style.setProperty('--dur', (2.5 + Math.random() * 2) + 's');
    el.style.setProperty('--rot', (Math.random() * 720 - 360) + 'deg');
  });
</script>
