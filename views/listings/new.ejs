
<section class="locara-form-page">
  <div class="locara-form-card">
    <header class="locara-form-head">
      <span class="locara-form-eyebrow">Host a stay</span>
      <p class="locara-form-copy"><i>Create a calm, premium listing for your guests with thoughtful details and modern presentation.</i></p>
    </header>

    <form action="/listings" method="POST" enctype="multipart/form-data" class="locara-form">

      <div class="locara-field-group">
        <label class="locara-field-label">Title</label>
        <input type="text"
               name="listing[title]"
               class="locara-input"
               required>
      </div>

      <div class="locara-field-group">
        <label class="locara-field-label">Description</label>
        <textarea name="listing[description]"
                  class="locara-textarea"
                  rows="4"
                  required></textarea>
      </div>

      <div class="locara-form-grid">
        <div class="locara-field-group">
          <label class="locara-field-label">Whole Property Price (₹)</label>
          <input type="number"
                 name="listing[price]"
                 class="locara-input"
                 required>
        </div>

        <div class="locara-field-group">
          <label class="locara-field-label">Total Rooms Available</label>
          <input type="number"
                 name="listing[totalRooms]"
                 min="1"
                 class="locara-input"
                 required>
        </div>
        <div class="locara-field-group">
          <label class="locara-field-label">Maximum Guests</label>
          <input type="number"
                name="listing[maxGuests]"
                min="1"
                value="2"
                class="locara-input"
                required>
        </div>
      </div>

      <div class="locara-form-grid">
        <div class="locara-field-group">
          <label class="locara-field-label">Location</label>
          <input type="text"
                 name="listing[location]"
                 class="locara-input"
                 placeholder="City, Country"
                 required>
        </div>

        <div class="locara-field-group">
          <label class="locara-field-label">Country</label>
          <input type="text"
                 name="listing[country]"
                 class="locara-input"
                 placeholder="India">
        </div>
      </div>

      <div class="locara-field-group">
        <label class="locara-field-label">Image URL (Optional)</label>
        <input type="text"
               name="listing[image][url]"
               class="locara-input"
               placeholder="Paste image link">
      </div>

      <div class="locara-field-group">
        <label class="locara-field-label">Upload Images</label>
        <label class="locara-file-card" tabindex="0">
          <span class="locara-file-title">Drag & drop images or click to browse</span>
          <span class="locara-file-sub">PNG, JPG, GIF up to 10MB</span>
          <input type="file"
                 name="images"
                 multiple
                 class="locara-file-input">
        </label>
      </div>

      <div class="locara-field-group">
        <label class="locara-field-label">Ownership Proof (Optional)</label>
        <label class="locara-file-card locara-file-card--small" tabindex="0">
          <span class="locara-file-title">Upload a document</span>
          <span class="locara-file-sub">PDF, JPG, PNG</span>
          <input type="file"
                 name="ownershipProof"
                 class="locara-file-input">
        </label>
      </div>

      <button type="submit" class="booking-card__reserve-btn">
        Create Listing
      </button>
    </form>
  </div>
</section>
