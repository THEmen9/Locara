
<div class="listings-page">

  <!-- ===== Header ===== -->
  <div class="listings-header">
    <div>
      <span class="header-eyebrow">Discover</span>
      <h1 class="header-title">
        Explore <span class="title-accent">Stays</span>
      </h1>
      <p class="header-sub">
        Handpicked places that feel like home
      </p>
    </div>

    <span class="listing-count-badge">
      <i class="bi bi-buildings"></i>
      <%= allListings.length %> stays available
    </span>
  </div>

  <!-- ===== Filters ===== -->
  <div class="filter-bar">
    <button class="filter-chip active" data-filter="all">All</button>
    <button class="filter-chip" data-filter="verified">
      <i class="bi bi-patch-check-fill"></i> Verified
    </button>
    <button class="filter-chip" data-filter="photos">
      Multiple Photos
    </button>
  </div>

  <!-- ===== Empty State ===== -->

  <% if (!allListings || allListings.length === 0) { %>
    <div class="empty-state">
      <i class="bi bi-house-slash" style="font-size:3rem; opacity:.4;"></i>
      <h3>No stays found</h3>
      <p>No stays match your current filters.
        Try reducing guests or changing destination.</p>

      <% if (currentUser) { %>
        <a href="/listings/new"
           class="locara-btn locara-btn--primary">
           <i class="bi bi-plus-circle"></i>
           Host your Stay
        </a>
      <% } %>
    </div>
  <% } %>

  <!-- ===== Grid ===== -->
  <div class="listings-grid">

    <% allListings.forEach(listing => { %>

      <%
        const isOwner = currentUser &&
          listing.owner &&
          (listing.owner._id.toString() === currentUser._id.toString() ||
           currentUser.role === "dev");
      %>
    <a href="/listings/<%= listing._id %>" class="listing-card-link">

      <div class="listing-card"
           data-verified="<%= listing.isVerifiedOwner ? 'true' : 'false' %>"
           data-photos="<%= (listing.images && listing.images.length > 1) ? 'true' : 'false' %>">

        <!-- ===== Image ===== -->
        <div class="card-image-wrap">
          <img
            src="<%= listing.images && listing.images.length
                    ? listing.images[0].url
                    : '/images/default.jpg' %>"
            alt="<%= listing.title %>"
            class="card-img"
            loading="lazy"
            onerror="this.onerror=null; this.src='/images/default.jpg';">
            
        </div>

        <!-- ===== Body ===== -->
         
      <div class="card-body-inner">

        <div class="card-top-row">
          <h3 class="card-listing-title">
            <%= listing.title %>
          </h3>

          <span class="rating-badge">
            ⭐ 4.8
          </span>
        </div>

        <% if (listing.location || listing.country) { %>
          <p class="card-location">
            <i class="bi bi-geo-alt"></i>
            <%= [listing.location, listing.country]
                  .filter(Boolean)
                  .join(', ') %>
          </p>
        <% } %>

        <div class="card-bottom-row">
          <div class="price-info">
            <span class="price-value">
              ₹ <%= listing.price.toLocaleString('en-IN') %>
            </span>
            <span class="price-unit">/ night</span>
          </div>
        </div>

      </div>

      </div>
       </a>
    <% }) %>
  </div>


  <!-- ===== Mobile Bottom Nav ===== -->

 
<nav class="mobile-bottom-nav d-lg-none" aria-label="Mobile navigation">
  <ul class="mb-nav">

    <li class="mb-nav__item">
      <a href="/listings" class="mb-nav__link mb-nav__link--active" aria-current="page">
        <i class="bi bi-search mb-nav__icon" aria-hidden="true"></i>
        <span class="mb-nav__label">Explore</span>
      </a>
    </li>

    <li class="mb-nav__item">
      <a href="/wishlists" class="mb-nav__link">
        <i class="bi bi-heart mb-nav__icon" aria-hidden="true"></i>
        <span class="mb-nav__label">Wishlists</span>
      </a>
    </li>

    <% if (currentUser) { %>
      <li class="mb-nav__item">
        <form action="/logout" method="POST" class="mb-nav__form">
          <button type="submit" class="mb-nav__link mb-nav__button">
            <i class="bi bi-box-arrow-right mb-nav__icon" aria-hidden="true"></i>
            <span class="mb-nav__label">Log out</span>
          </button>
        </form>
      </li>
    <% } else { %>
      <li class="mb-nav__item">
        <a href="/login" class="mb-nav__link">
          <i class="bi bi-person mb-nav__icon" aria-hidden="true"></i>
          <span class="mb-nav__label">Log in</span>
        </a>
      </li>
    <% } %>

  </ul>
</nav>

</div>


<script>
(function () {
  const chips = document.querySelectorAll('.filter-chip');
  const cards = document.querySelectorAll('.listing-card');

  chips.forEach(chip => {
    chip.addEventListener('click', function () {

      chips.forEach(c => c.classList.remove('active'));
      this.classList.add('active');

      const filter = this.dataset.filter;

      cards.forEach(card => {
        if (filter === 'all') {
          card.style.display = '';
        } else if (filter === 'verified') {
          card.style.display =
            card.dataset.verified === 'true' ? '' : 'none';
        } else if (filter === 'photos') {
          card.style.display =
            card.dataset.photos === 'true' ? '' : 'none';
        }
      });

    });
  });
}());
</script>